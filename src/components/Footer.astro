---
---
<footer>
  <div class="container footer-inner">
    <div class="footer-brand">
      <div class="footer-logo">New Castle International Corp.</div>
      <div class="footer-sub">Est. 2014 · Wilmington, Delaware</div>
      <p class="footer-desc">Connecting New Castle County and the Mid-Atlantic region to the world through education, culture, and economic development.</p>
    </div>
    <div class="footer-nav-group">
      <div class="footer-nav-label">The Region</div>
      <a href="/region">Overview</a>
      <a href="/industries">Industries</a>
      <a href="/education">Education</a>
      <a href="/arts">Arts &amp; Culture</a>
    </div>
    <div class="footer-nav-group">
      <div class="footer-nav-label">Partnerships</div>
      <a href="/qiqihar">Qiqihar, China</a>
      <a href="/our-work">Our Work</a>
      <a href="/partner">Partner With Us</a>
    </div>
    <div class="footer-nav-group">
      <div class="footer-nav-label">Company</div>
      <a href="/about">About NCIC</a>
      <a href="/news">News &amp; Insights</a>
      <a href="/contact">Contact</a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {new Date().getFullYear()} New Castle International Corp. All rights reserved.</span>
      <span>info@newcastleinternational.com</span>
    </div>
  </div>
</footer>

<style>
footer { background: var(--navy); border-top: 2px solid var(--gold); padding-top: 64px; }
.footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 48px; }
.footer-logo { font-family: 'Georgia', serif; font-size: 14px; letter-spacing: .15em; text-transform: uppercase; color: var(--offwhite); margin-bottom: 4px; }
.footer-sub { font-family: 'Arial', sans-serif; font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
.footer-desc { font-family: 'Arial', sans-serif; font-size: 13px; color: #475569; line-height: 1.7; }
.footer-nav-label { font-family: 'Arial', sans-serif; font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; display: block; }
.footer-nav-group { display: flex; flex-direction: column; gap: 10px; }
.footer-nav-group a { font-family: 'Arial', sans-serif; font-size: 13px; color: #64748B; text-decoration: none; transition: color .2s; }
.footer-nav-group a:hover { color: var(--offwhite); }
.footer-bottom { border-top: 1px solid rgba(255,255,255,.06); padding: 20px 0; }
.footer-bottom-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
.footer-bottom span { font-family: 'Arial', sans-serif; font-size: 11px; color: #334155; letter-spacing: .05em; }
@media (max-width: 900px) { .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; } }
@media (max-width: 600px) { .footer-inner { grid-template-columns: 1fr; } .footer-bottom-inner { flex-direction: column; text-align: center; } }
</style>
