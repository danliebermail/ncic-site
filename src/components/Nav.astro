---
const links = [
  { href: '/#about', label: 'About' },
  { href: '/our-work', label: 'Our Work' },
  { href: '/#partnerships', label: 'Partnerships' },
  { href: '/partner', label: 'Partner With Us' },
  { href: '/contact', label: 'Contact' },
];
---

<nav>
  <a href="/" class="nav-logo">
    New Castle International Corp.
    <span>Est. 2014 · Wilmington, Delaware</span>
  </a>
  <ul class="nav-links">
    {links.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<style>
  nav{background:var(--navy);padding:0 48px;display:flex;justify-content:space-between;align-items:center;height:64px;position:sticky;top:0;z-index:100;border-bottom:2px solid var(--gold)}
  .nav-logo{font-family:'Georgia',serif;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--offwhite);font-weight:normal;text-decoration:none;flex-shrink:0}
  .nav-logo span{color:var(--gold);display:block;font-size:10px;letter-spacing:.25em;margin-top:2px}
  .nav-links{display:flex;gap:32px;list-style:none}
  .nav-links a{color:#CBD5E0;text-decoration:none;font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.15em;text-transform:uppercase;transition:color .2s}
  .nav-links a:hover{color:var(--gold)}
  @media(max-width:900px){nav{padding:0 24px}.nav-links{gap:20px}}
  @media(max-width:768px){.nav-links{display:none}}
</style>
