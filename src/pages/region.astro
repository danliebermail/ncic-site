---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="The Region — New Castle International Corp.">
  <Nav />

  <section class="page-hero" style="background-image:linear-gradient(to bottom,rgba(13,31,60,.75),rgba(13,31,60,.95)),url('/images/wilmington-aerial.png');background-size:cover;background-position:center">
    <div class="container">
      <div class="section-label">The Region</div>
      <h1>New Castle County &amp;<br>the <em>Mid-Atlantic Corridor</em></h1>
      <p class="sub">NCIC represents one of the most economically powerful, educationally rich, and culturally significant regions in the United States — a 90-mile corridor between New York City and Washington D.C. that punches far above its weight on the global stage.</p>
    </div>
  </section>

  <section class="region-stats">
    <div class="container stats-grid">
      <div class="stat-card"><span class="snum">$29.1B</span><span class="slbl">Metro Export Value (2024)</span></div>
      <div class="stat-card"><span class="snum">$5.5B</span><span class="slbl">Delaware Goods Exports (2025)</span></div>
      <div class="stat-card"><span class="snum">36K</span><span class="slbl">Foreign-Employed Delaware Workers</span></div>
      <div class="stat-card"><span class="snum">&gt;60%</span><span class="slbl">NYSE Companies Incorporated in DE</span></div>
      <div class="stat-card"><span class="snum">$103B</span><span class="slbl">Delaware State GDP (2024)</span></div>
      <div class="stat-card"><span class="snum">#1</span><span class="slbl">Most Business-Friendly State, USA</span></div>
    </div>
  </section>

  <section class="why-region">
    <div class="container two-col">
      <div>
        <div class="section-label">Why This Region</div>
        <h2>The Center of Everything</h2>
        <p>New Castle County sits at the geographic heart of the Northeast Megalopolis — the most densely populated and economically productive urban corridor in the Western Hemisphere. Within a 90-minute drive: New York City, Philadelphia, Baltimore, and Washington D.C.</p>
        <p>This isn't just geography. It's access to 50 million consumers, the world's largest financial markets, the US federal government, and the most concentrated cluster of Fortune 500 companies outside of Silicon Valley.</p>
        <p>For international investors, companies, and governments looking for a foothold in the American market, New Castle County offers something unique: the infrastructure and connectivity of a major metro area, with the business-friendly legal environment, lower costs, and government accessibility of a small state.</p>
        <p>Delaware's liberal incorporation law — in effect since 1899 — has made it the legal home of more than 60% of Fortune 500 companies. The state's corporate infrastructure, combined with NCC's strategic position and the Port of Wilmington, makes this region uniquely positioned for international partnership.</p>
      </div>
      <div>
        <img src="/images/world-map.png" alt="Delaware to China — global corridor" style="width:100%;margin-bottom:3px;display:block" />
        <img src="/images/wilmington-waterfront.png" alt="Wilmington waterfront" style="width:100%;display:block;height:200px;object-fit:cover" />
      </div>
    </div>
  </section>

  <section class="sectors-band">
    <div class="container">
      <div class="section-label">Key Sectors</div>
      <h2>What New Castle County Does Best</h2>
      <div class="sectors-grid">
        <a href="/industries#lifesciences" class="sector-card">
          <div class="sector-icon">⬡</div>
          <h3>Life Sciences</h3>
          <p>AstraZeneca, DuPont, ILC Dover, and Agilent anchor a world-class life sciences cluster spanning pharmaceuticals, biotech, advanced materials, and medical devices.</p>
          <span class="sector-link">Explore →</span>
        </a>
        <a href="/industries#manufacturing" class="sector-card">
          <div class="sector-icon">⬡</div>
          <h3>Advanced Manufacturing</h3>
          <p>21,740 manufacturing workers in NCC alone. Transportation equipment exports valued at nearly $900M including aerospace parts, aircraft components, and automotive materials.</p>
          <span class="sector-link">Explore →</span>
        </a>
        <a href="/industries#chemicals" class="sector-card">
          <div class="sector-icon">⬡</div>
          <h3>Chemicals &amp; Pharma</h3>
          <p>Wilmington is the administrative and research capital of the global chemical industry. $1.6 billion in chemical exports in 2025 — Delaware's single largest export category.</p>
          <span class="sector-link">Explore →</span>
        </a>
        <a href="/industries#financial" class="sector-card">
          <div class="sector-icon">⬡</div>
          <h3>Financial Services</h3>
          <p>Delaware's corporation-friendly legal system makes it the domicile of choice for American and international businesses. Major banking and financial services hub.</p>
          <span class="sector-link">Explore →</span>
        </a>
        <a href="/industries#logistics" class="sector-card">
          <div class="sector-icon">⬡</div>
          <h3>Logistics &amp; Port</h3>
          <p>The Port of Wilmington — currently under expansion — provides direct Atlantic access and connects to major rail and highway networks serving the entire Northeast corridor.</p>
          <span class="sector-link">Explore →</span>
        </a>
        <a href="/industries#food" class="sector-card">
          <div class="sector-icon">⬡</div>
          <h3>Food &amp; Agriculture</h3>
          <p>Delaware's food processing industry employs 29% of the state's industrial workers. $364M in agricultural exports in 2024. A natural partner for Qiqihar's organic food sector.</p>
          <span class="sector-link">Explore →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="corridor">
    <div class="container">
      <div class="section-label">Geographic Position</div>
      <h2>The Mid-Atlantic Advantage</h2>
      <div class="corridor-grid">
        <div class="corridor-item">
          <h4>New York City</h4>
          <span class="distance">~90 min</span>
          <p>World's largest financial center, global media capital, major port. Direct Amtrak and I-95 access.</p>
        </div>
        <div class="corridor-item">
          <h4>Philadelphia</h4>
          <span class="distance">~25 min</span>
          <p>5th largest US city. Major education, healthcare, and manufacturing hub. Philadelphia International Airport.</p>
        </div>
        <div class="corridor-item">
          <h4>Baltimore</h4>
          <span class="distance">~60 min</span>
          <p>Major East Coast port. Johns Hopkins, University of Maryland. Federal government contractor hub.</p>
        </div>
        <div class="corridor-item">
          <h4>Washington D.C.</h4>
          <span class="distance">~90 min</span>
          <p>US federal government, World Bank, IMF, foreign embassies. Policy and regulatory access.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="region-links">
    <div class="container rlinks-grid">
      <a href="/education" class="rlink-card">
        <div class="rlink-icon">📚</div>
        <h3>Education</h3>
        <p>University of Delaware, Wilmington University, Del Tech — plus Penn, Drexel, Temple within 30 miles.</p>
        <span>Explore Education →</span>
      </a>
      <a href="/arts" class="rlink-card">
        <div class="rlink-icon">🎨</div>
        <h3>Arts &amp; Culture</h3>
        <p>The Brandywine School, Delaware Art Museum, Winterthur, Hagley. World-class cultural infrastructure.</p>
        <span>Explore Arts →</span>
      </a>
      <a href="/partner" class="rlink-card">
        <div class="rlink-icon">🌐</div>
        <h3>Partner With Us</h3>
        <p>Is your city or institution interested in what this region has to offer? Start the conversation.</p>
        <span>Get in Touch →</span>
      </a>
    </div>
  </section>

  <Footer />
</Base>

<style>
.page-hero{padding:80px 0;border-bottom:2px solid var(--gold);color:var(--offwhite)}
.page-hero h1{font-size:clamp(28px,4vw,52px);font-weight:normal;margin-bottom:20px;line-height:1.1}
.page-hero h1 em{font-style:normal;color:var(--gold)}
.page-hero .sub{font-family:'Arial',sans-serif;font-size:15px;color:#94A3B8;max-width:660px;line-height:1.8}
.region-stats{background:var(--navy);padding:48px 0}
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(255,255,255,.05)}
.stat-card{background:var(--navy);padding:32px 24px;text-align:center;border:1px solid rgba(201,168,76,.1)}
.snum{display:block;font-size:clamp(24px,3vw,36px);color:var(--gold);margin-bottom:8px}
.slbl{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#64748B}
.why-region{padding:80px 0;background:var(--offwhite)}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.why-region h2{font-size:clamp(24px,3vw,36px);color:var(--navy);margin-bottom:24px;font-weight:normal}
.why-region p{font-family:'Arial',sans-serif;font-size:15px;color:var(--muted);line-height:1.8;margin-bottom:16px}
.sectors-band{padding:80px 0;background:var(--light)}
.sectors-band h2{font-size:clamp(24px,3vw,36px);color:var(--navy);margin-bottom:40px;font-weight:normal}
.sectors-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:#D0C9BC}
.sector-card{background:var(--offwhite);padding:32px;text-decoration:none;display:block;transition:background .2s}
.sector-card:hover{background:var(--navy)}
.sector-card:hover h3,.sector-card:hover p,.sector-card:hover .sector-link{color:var(--offwhite)}
.sector-icon{font-size:24px;margin-bottom:16px;display:block;color:var(--gold)}
.sector-card h3{font-size:18px;color:var(--navy);margin-bottom:10px;font-weight:normal;transition:color .2s}
.sector-card p{font-family:'Arial',sans-serif;font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:16px;transition:color .2s}
.sector-link{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold)}
.corridor{padding:80px 0;background:var(--navy);color:var(--offwhite)}
.corridor h2{font-size:clamp(24px,3vw,36px);color:var(--offwhite);margin-bottom:40px;font-weight:normal}
.corridor-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
.corridor-item{border-top:2px solid var(--gold);padding-top:24px}
.corridor-item h4{font-size:17px;color:var(--offwhite);margin-bottom:8px;font-weight:normal}
.distance{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:12px}
.corridor-item p{font-family:'Arial',sans-serif;font-size:13px;color:#94A3B8;line-height:1.7}
.region-links{padding:80px 0;background:var(--offwhite)}
.rlinks-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:var(--light)}
.rlink-card{background:var(--offwhite);padding:40px 32px;text-decoration:none;display:block;transition:background .2s}
.rlink-card:hover{background:var(--navy)}
.rlink-card:hover h3,.rlink-card:hover p,.rlink-card:hover span{color:var(--offwhite)}
.rlink-icon{font-size:32px;display:block;margin-bottom:16px}
.rlink-card h3{font-size:20px;color:var(--navy);margin-bottom:12px;font-weight:normal;transition:color .2s}
.rlink-card p{font-family:'Arial',sans-serif;font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:20px;transition:color .2s}
.rlink-card span{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold)}
@media(max-width:900px){.stats-grid,.sectors-grid,.rlinks-grid{grid-template-columns:repeat(2,1fr)}.corridor-grid{grid-template-columns:repeat(2,1fr)}.two-col{grid-template-columns:1fr;gap:40px}}
@media(max-width:600px){.stats-grid,.sectors-grid,.corridor-grid,.rlinks-grid{grid-template-columns:1fr}}
</style>
