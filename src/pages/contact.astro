---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Contact — New Castle International Corp.">
  <Nav />

  <section class="contact-hero">
    <div class="container">
      <div class="section-label">Get in Touch</div>
      <h1>Ready to Build<br>Something Together</h1>
      <p class="sub">Whether you represent a government, an institution, or a business with international ambitions — we'd like to hear from you.</p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container contact-grid">
      <div class="contact-info">
        <div class="info-block">
          <div class="info-label">Inquiries</div>
          <p>info@newcastleinternational.com</p>
        </div>
        <div class="info-block">
          <div class="info-label">Based In</div>
          <p>New Castle County, Delaware, USA</p>
        </div>
        <div class="info-block">
          <div class="info-label">Focus Areas</div>
          <p>Education Exchange · Economic Development<br>Government Relations · Cultural Programs</p>
        </div>
        <div class="info-block">
          <div class="info-label">Active Partnerships</div>
          <p>Qiqihar, Heilongjiang Province, China<br>Ningbo, Zhejiang Province, China</p>
        </div>
      </div>

      <form class="contact-form" method="POST" action="/api/contact">
        <div class="form-row">
          <div class="field">
            <label for="fname">First Name</label>
            <input type="text" id="fname" name="firstName" required />
          </div>
          <div class="field">
            <label for="lname">Last Name</label>
            <input type="text" id="lname" name="lastName" required />
          </div>
        </div>
        <div class="field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="field">
          <label for="org">Organization / Institution</label>
          <input type="text" id="org" name="organization" />
        </div>
        <div class="field">
          <label for="interest">Area of Interest</label>
          <select id="interest" name="interest">
            <option value="" disabled selected>Select one</option>
            <option>Education Exchange</option>
            <option>Economic Development</option>
            <option>Government Relations</option>
            <option>Cultural Programming</option>
            <option>Investment Inquiry</option>
            <option>Other</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit">Send Inquiry →</button>
      </form>
    </div>
  </section>

  <Footer />
</Base>

<style>
.contact-hero{background:var(--navy);padding:80px 0;color:var(--offwhite);border-bottom:2px solid var(--gold)}
.contact-hero h1{font-size:clamp(32px,4vw,56px);color:var(--offwhite);margin-bottom:20px;font-weight:normal}
.contact-hero .sub{font-family:'Arial',sans-serif;font-size:16px;color:#94A3B8;max-width:500px;line-height:1.7}
.contact-body{padding:80px 0;background:var(--offwhite)}
.contact-grid{display:grid;grid-template-columns:1fr 1.6fr;gap:80px;align-items:start}
.info-block{margin-bottom:32px}
.info-label{font-family:'Arial',sans-serif;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);margin-bottom:8px}
.info-block p{font-family:'Arial',sans-serif;font-size:14px;color:var(--muted);line-height:1.7}
.contact-form{display:flex;flex-direction:column;gap:20px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.field{display:flex;flex-direction:column;gap:6px}
label{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
input,select,textarea{background:white;border:1px solid #D0C9BC;padding:14px 16px;font-family:'Arial',sans-serif;font-size:14px;color:var(--text);outline:none;transition:border-color .2s;width:100%}
input:focus,select:focus,textarea:focus{border-color:var(--gold)}
textarea{resize:vertical}
button{background:var(--navy);color:var(--offwhite);border:none;padding:16px 32px;font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;transition:background .2s;align-self:flex-start}
button:hover{background:var(--slate)}
@media(max-width:768px){.contact-grid{grid-template-columns:1fr;gap:48px}.form-row{grid-template-columns:1fr}.contact-hero{padding:56px 0}}
</style>
