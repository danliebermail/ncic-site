---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Industries — New Castle International Corp.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <div class="section-label">Industries</div>
      <h1>What New Castle County<br><em>Produces for the World</em></h1>
      <p class="sub">New Castle County is Delaware's economic engine — home to world-class companies in life sciences, advanced manufacturing, chemicals, financial services, logistics, and agriculture. This is what we represent to the world.</p>
    </div>
  </section>

  <section class="industry-intro">
    <div class="container two-col">
      <div>
        <h2>A Two-Way Opportunity</h2>
        <p>International partnerships work best when both sides have something the other needs. NCIC's role is to identify those intersections — matching Delaware's export strengths with the import demands of partner cities, and vice versa.</p>
        <p>The Philadelphia-Camden-Wilmington metropolitan area exported <strong>$29.1 billion</strong> in goods in 2024. Delaware alone exported <strong>$5.5 billion</strong> in 2025. This region produces things the world wants — and it wants things the world produces.</p>
      </div>
      <div class="trade-flow">
        <div class="flow-side">
          <div class="flow-label">Delaware → World</div>
          <div class="flow-items">
            <div class="flow-item">Chemicals &amp; Pharmaceuticals — $1.6B</div>
            <div class="flow-item">Transportation Equipment — $900M</div>
            <div class="flow-item">Agricultural Products — $364M</div>
            <div class="flow-item">Advanced Materials</div>
            <div class="flow-item">Financial Services</div>
            <div class="flow-item">Educational Programming</div>
          </div>
        </div>
        <div class="flow-arrow">⇄</div>
        <div class="flow-side">
          <div class="flow-label">World → Delaware</div>
          <div class="flow-items">
            <div class="flow-item">Organic Food Products</div>
            <div class="flow-item">Heavy Machinery &amp; Equipment</div>
            <div class="flow-item">Consumer Goods &amp; Brands</div>
            <div class="flow-item">International Investment</div>
            <div class="flow-item">Student Enrollment</div>
            <div class="flow-item">Cultural Programming</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div id="lifesciences" class="industry-section alt">
    <div class="container industry-grid">
      <div class="industry-text">
        <div class="ind-tag">Sector 01</div>
        <h2>Life Sciences</h2>
        <p>New Castle County is home to one of the most significant life sciences clusters in the United States. AstraZeneca — Delaware's largest industrial employer — anchors a pharmaceutical ecosystem that includes DuPont, ILC Dover, and Agilent Technologies.</p>
        <p>The sector spans pharmaceuticals, biotech research, advanced materials, medical devices, and diagnostics. Delaware's proximity to major research universities, the NIH corridor in Maryland, and major hospital systems in Philadelphia creates an unparalleled innovation environment.</p>
        <div class="ind-opportunities">
          <div class="ind-opp-label">International Opportunities</div>
          <div class="ind-opp">Clinical trial partnerships with Chinese research institutions</div>
          <div class="ind-opp">API and raw material sourcing from Chinese pharmaceutical manufacturers</div>
          <div class="ind-opp">Market entry for Delaware biotech companies in China</div>
          <div class="ind-opp">Joint research programs between UD and Chinese universities</div>
        </div>
      </div>
      <div class="industry-companies">
        <div class="company-card"><h4>AstraZeneca</h4><p>Global pharmaceutical leader. Delaware's largest industrial employer. Major R&amp;D presence in Wilmington.</p></div>
        <div class="company-card"><h4>DuPont</h4><p>Founded in Delaware in 1802. Global leader in specialty chemicals, advanced materials, and electronic components.</p></div>
        <div class="company-card"><h4>ILC Dover</h4><p>Advanced flexible materials for aerospace, pharmaceutical, and defense. Producer of NASA spacesuits.</p></div>
        <div class="company-card"><h4>Agilent Technologies</h4><p>Leader in life sciences diagnostics and applied chemicals. Significant Delaware manufacturing presence.</p></div>
      </div>
    </div>
  </div>

  <div id="manufacturing" class="industry-section">
    <div class="container industry-grid">
      <div class="industry-text">
        <div class="ind-tag">Sector 02</div>
        <h2>Advanced Manufacturing</h2>
        <p>New Castle County is Delaware's largest manufacturing county, home to 21,740 manufacturing workers across nearly 600 industrial companies. The sector ranges from aerospace components to structural metals, electrical equipment, and paper products.</p>
        <p>Transportation equipment is Delaware's second-largest manufacturing export at nearly $900 million — including aircraft parts, aerospace components, and automotive materials. The modernized Coastal Zone Act is opening previously underutilized industrial sites for new manufacturing development.</p>
        <div class="ind-opportunities">
          <div class="ind-opp-label">International Opportunities</div>
          <div class="ind-opp">Chinese machinery manufacturers seeking US distribution partners</div>
          <div class="ind-opp">Joint manufacturing ventures utilizing NCC's skilled workforce</div>
          <div class="ind-opp">Technology transfer agreements in precision manufacturing</div>
          <div class="ind-opp">Supply chain partnerships for aerospace and automotive components</div>
        </div>
      </div>
      <div class="industry-stats-panel">
        <div class="istat"><span>21,740</span><span>Manufacturing workers in NCC</span></div>
        <div class="istat"><span>~600</span><span>Industrial companies in Delaware</span></div>
        <div class="istat"><span>$900M</span><span>Transportation equipment exports</span></div>
        <div class="istat"><span>$6.7B</span><span>NCC goods-producing GDP (2024)</span></div>
      </div>
    </div>
  </div>

  <div id="chemicals" class="industry-section alt">
    <div class="container industry-grid">
      <div class="industry-text">
        <div class="ind-tag">Sector 03</div>
        <h2>Chemicals &amp; Pharmaceuticals</h2>
        <p>Wilmington is widely recognized as the chemical capital of the world. DuPont, Hercules, and AstraZeneca established Wilmington as a global center for chemical research, development, and administration — a legacy that continues to shape the regional economy.</p>
        <p>Delaware's chemical exports totaled $1.6 billion in 2025 — the state's single largest export category. Products include pigments, nylon, petrochemicals, pharmaceuticals, synthetic rubber, and specialty materials.</p>
        <div class="ind-opportunities">
          <div class="ind-opp-label">International Opportunities</div>
          <div class="ind-opp">Specialty chemical distribution partnerships in Chinese markets</div>
          <div class="ind-opp">Raw material sourcing from Chinese chemical manufacturers</div>
          <div class="ind-opp">Pharmaceutical ingredient supply chain development</div>
          <div class="ind-opp">Environmental technology partnerships (Delaware Coastal Zone expertise)</div>
        </div>
      </div>
      <div class="industry-stats-panel">
        <div class="istat"><span>$1.6B</span><span>Chemical exports from Delaware (2025)</span></div>
        <div class="istat"><span>#1</span><span>Delaware's largest export category</span></div>
        <div class="istat"><span>200+</span><span>Years of chemical industry in Wilmington</span></div>
      </div>
    </div>
  </div>

  <div id="financial" class="industry-section">
    <div class="container industry-grid">
      <div class="industry-text">
        <div class="ind-tag">Sector 04</div>
        <h2>Financial Services</h2>
        <p>Delaware's 1899 corporation law created what is still the most business-friendly legal environment in the United States. More than 60% of Fortune 500 companies are incorporated in Delaware. Over 1 million business entities call Delaware home — including thousands of American and international corporations.</p>
        <p>For international investors, Delaware's legal infrastructure offers unparalleled protection, flexibility, and access to the American financial system. The Court of Chancery — a specialized business court with no jury trials — provides fast, expert resolution of commercial disputes.</p>
        <div class="ind-opportunities">
          <div class="ind-opp-label">International Opportunities</div>
          <div class="ind-opp">Delaware LLC and corporation formation for international companies entering the US market</div>
          <div class="ind-opp">EB-5 investment visa pathway — $800K minimum, creates 10 jobs, path to permanent residency</div>
          <div class="ind-opp">Banking and financial services partnerships</div>
          <div class="ind-opp">International holding company structures</div>
        </div>
      </div>
      <div class="industry-stats-panel">
        <div class="istat"><span>&gt;60%</span><span>Fortune 500 companies incorporated in DE</span></div>
        <div class="istat"><span>1M+</span><span>Business entities domiciled in Delaware</span></div>
        <div class="istat"><span>$800K</span><span>EB-5 minimum investment (NCC TEA)</span></div>
        <div class="istat"><span>1899</span><span>Year Delaware corporation law established</span></div>
      </div>
    </div>
  </div>

  <div id="logistics" class="industry-section alt">
    <div class="container industry-grid">
      <div class="industry-text">
        <div class="ind-tag">Sector 05</div>
        <h2>Logistics &amp; Port</h2>
        <p>The Port of Wilmington sits on the Delaware River, 65 miles from the Atlantic — strategically positioned to serve the entire Northeast corridor. Currently operated by Enstructure and undergoing significant expansion, the port is positioned to become a major gateway for international trade.</p>
        <p>The port connects to I-95, I-295, the Northeast Corridor rail line, and CSX freight rail — providing direct access to 50 million consumers within a 4-hour drive. The International Longshoremen's Association local, a major force in Wilmington's economy, provides a skilled and reliable workforce.</p>
        <div class="ind-opportunities">
          <div class="ind-opp-label">International Opportunities</div>
          <div class="ind-opp">Import distribution for Chinese organic food products entering the US market</div>
          <div class="ind-opp">Container shipping partnerships through the port expansion</div>
          <div class="ind-opp">Cold storage and food processing facilities for Chinese agricultural exports</div>
          <div class="ind-opp">Logistics and warehousing partnerships for Chinese goods entering the Northeast</div>
        </div>
      </div>
      <div class="industry-stats-panel">
        <div class="istat"><span>65 mi</span><span>From Atlantic Ocean</span></div>
        <div class="istat"><span>50M</span><span>Consumers within 4-hour drive</span></div>
        <div class="istat"><span>I-95</span><span>Direct access to Northeast corridor</span></div>
        <div class="istat"><span>Active</span><span>Port expansion underway (Enstructure)</span></div>
      </div>
    </div>
  </div>

  <div id="food" class="industry-section">
    <div class="container industry-grid">
      <div class="industry-text">
        <div class="ind-tag">Sector 06</div>
        <h2>Food &amp; Agriculture</h2>
        <p>Food processing is Delaware's largest industrial sector by employment — accounting for 29% of the state's industrial workforce. Delaware exported $364 million in agricultural products in 2024, with strengths in poultry, soybeans, corn, and dairy.</p>
        <p>This sector presents one of the most direct partnership opportunities with Qiqihar — China's designated Capital of Organic Food, with 1,200+ food manufacturing companies. The complementary strengths of Delaware food processing infrastructure and Qiqihar's organic food production create natural trade and investment synergies.</p>
        <div class="ind-opportunities">
          <div class="ind-opp-label">International Opportunities</div>
          <div class="ind-opp">US distribution partnerships for Qiqihar organic food brands</div>
          <div class="ind-opp">Food processing technology and equipment trade</div>
          <div class="ind-opp">Cold chain logistics development for agricultural imports</div>
          <div class="ind-opp">American food brand distribution in Chinese markets through Qiqihar network</div>
        </div>
      </div>
      <div class="industry-stats-panel">
        <div class="istat"><span>29%</span><span>Delaware industrial jobs in food processing</span></div>
        <div class="istat"><span>$364M</span><span>Agricultural exports (2024)</span></div>
        <div class="istat"><span>1,200+</span><span>Food companies in Qiqihar</span></div>
        <div class="istat"><span>Direct</span><span>Synergy with Qiqihar organic food sector</span></div>
      </div>
    </div>
  </div>

  <section class="industries-cta">
    <div class="container ind-cta-inner">
      <div>
        <h2>See an Opportunity?</h2>
        <p>If your city, company, or institution sees a potential match with what New Castle County produces and needs — let's talk.</p>
      </div>
      <a href="/partner" class="gold-btn">Start the Conversation →</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
.page-hero{background:var(--navy);padding:80px 0;border-bottom:2px solid var(--gold);color:var(--offwhite)}
.page-hero h1{font-size:clamp(28px,4vw,50px);font-weight:normal;margin-bottom:20px;line-height:1.1}
.page-hero h1 em{font-style:normal;color:var(--gold)}
.page-hero .sub{font-family:'Arial',sans-serif;font-size:15px;color:#94A3B8;max-width:660px;line-height:1.8}
.industry-intro{padding:80px 0;background:var(--offwhite)}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.industry-intro h2{font-size:clamp(24px,3vw,34px);color:var(--navy);margin-bottom:20px;font-weight:normal}
.industry-intro p{font-family:'Arial',sans-serif;font-size:15px;color:var(--muted);line-height:1.8;margin-bottom:16px}
.trade-flow{display:flex;gap:16px;align-items:start}
.flow-side{flex:1}
.flow-label{font-family:'Arial',sans-serif;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:block}
.flow-item{font-family:'Arial',sans-serif;font-size:13px;color:var(--text);padding:10px 12px;border-left:2px solid var(--light);margin-bottom:4px}
.flow-arrow{font-size:32px;color:var(--gold);padding-top:32px}
.industry-section{padding:80px 0;border-bottom:1px solid var(--light)}
.industry-section.alt{background:var(--light)}
.industry-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:start}
.ind-tag{font-family:'Arial',sans-serif;font-size:10px;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.ind-tag::before{content:'';display:block;width:20px;height:1px;background:var(--gold)}
.industry-text h2{font-size:clamp(22px,3vw,32px);color:var(--navy);margin-bottom:20px;font-weight:normal}
.industry-text p{font-family:'Arial',sans-serif;font-size:15px;color:var(--muted);line-height:1.8;margin-bottom:16px}
.ind-opportunities{margin-top:32px;padding:24px;background:var(--navy)}
.ind-opp-label{font-family:'Arial',sans-serif;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:block}
.ind-opp{font-family:'Arial',sans-serif;font-size:13px;color:#CBD5E0;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:start;gap:10px}
.ind-opp::before{content:'→';color:var(--gold);flex-shrink:0}
.ind-opp:last-child{border-bottom:none}
.industry-companies{display:flex;flex-direction:column;gap:2px}
.company-card{background:var(--offwhite);padding:24px;border-left:3px solid var(--gold)}
.industry-section.alt .company-card{background:white}
.company-card h4{font-size:16px;color:var(--navy);margin-bottom:8px;font-weight:normal}
.company-card p{font-family:'Arial',sans-serif;font-size:13px;color:var(--muted);line-height:1.6}
.industry-stats-panel{display:flex;flex-direction:column;gap:2px}
.istat{background:var(--navy);padding:28px 24px;border-left:3px solid var(--gold)}
.industry-section.alt .istat{background:var(--slate)}
.istat span:first-child{display:block;font-size:clamp(22px,2.5vw,30px);color:var(--gold);margin-bottom:6px}
.istat span:last-child{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#94A3B8}
.industries-cta{background:var(--gold);padding:64px 0}
.ind-cta-inner{display:flex;justify-content:space-between;align-items:center;gap:48px;flex-wrap:wrap}
.industries-cta h2{font-size:clamp(22px,3vw,34px);color:var(--navy);margin-bottom:12px;font-weight:normal}
.industries-cta p{font-family:'Arial',sans-serif;font-size:15px;color:var(--navy);opacity:.8;max-width:480px}
.gold-btn{background:var(--navy);color:var(--offwhite);padding:16px 32px;font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;white-space:nowrap;flex-shrink:0;transition:background .2s}
.gold-btn:hover{background:var(--slate)}
@media(max-width:900px){.two-col,.industry-grid{grid-template-columns:1fr;gap:40px}.trade-flow{flex-direction:column}.flow-arrow{display:none}.ind-cta-inner{flex-direction:column}}
@media(max-width:768px){.industry-section,.industry-intro,.industries-cta{padding:56px 0}}
</style>
