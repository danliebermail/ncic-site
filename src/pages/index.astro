---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="New Castle International Corp. — Connecting Delaware to the World">
  <Nav />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">New Castle International Corp.</div>
      <h1>Connecting Delaware<br>to the <em>World</em></h1>
      <p class="hero-sub">Since 2014, NCIC has built government-to-government relationships between New Castle County and international partners — linking Delaware's economic assets to global opportunity through education, culture, and trade.</p>
      <a href="/contact" class="hero-cta">Get in Touch →</a>
      <div class="hero-stats">
        <div class="hero-stat"><span class="num">2014</span><span class="lbl">Founded</span></div>
        <div class="hero-stat"><span class="num">2</span><span class="lbl">Active International Relationships</span></div>
        <div class="hero-stat"><span class="num">6M+</span><span class="lbl">People in Partner Cities</span></div>
        <div class="hero-stat"><span class="num">NCC</span><span class="lbl">New Castle County · Delaware</span></div>
      </div>
    </div>
  </section>

  <!-- PHOTO BAND -->
  <section class="photo-band">
    <div class="pb-label">2014–2016 · Delaware–China Economic Summit</div>
    <div class="pb-grid">
      <a href="/our-work"><img src="/images/gallery/boardroom-full.jpg" alt="Boardroom session" loading="lazy" /></a>
      <a href="/our-work"><img src="/images/gallery/meeting-trio.jpg" alt="Delegation meeting" loading="lazy" /></a>
      <a href="/our-work"><img src="/images/gallery/delegation-dinner.jpg" alt="Delegation dinner" loading="lazy" /></a>
      <a href="/our-work"><img src="/images/gallery/gift-exchange-group.jpg" alt="Gift exchange ceremony" loading="lazy" /></a>
      <a href="/our-work"><img src="/images/gallery/winson-gordons-office.jpg" alt="County Executive office" loading="lazy" /></a>
      <a href="/our-work"><img src="/images/gallery/agreement-signing.jpg" alt="Agreement signing" loading="lazy" /></a>
    </div>
    <a href="/our-work" class="pb-cta">View Full Case Study →</a>
  </section>

  <!-- ABOUT -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-label">What We Do</div>
      <h2>Bridging Local Strength with Global Reach</h2>
      <p class="intro">NCIC works at the intersection of government, business, and community — identifying international partners whose strengths align with Delaware's economic development priorities, then building the relationships that make exchange real.</p>
      <div class="pillars">
        <div class="pillar"><span class="pnum">I</span><div class="pbar"></div><h3>Education &amp; Cultural Exchange</h3><p>Student exchange programs, curriculum partnerships, and cultural initiatives that build lasting people-to-people connections between Delaware and partner cities.</p></div>
        <div class="pillar"><span class="pnum">II</span><div class="pbar"></div><h3>Economic Development</h3><p>Connecting international investors and business leaders with Delaware's economic infrastructure through trade missions, business symposia, and introductions to county officials.</p></div>
        <div class="pillar"><span class="pnum">III</span><div class="pbar"></div><h3>Government Relations</h3><p>Operating at the county government level to facilitate formal agreements, intergovernmental delegations, and bilateral frameworks that outlast any single administration.</p></div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="history-band" id="history">
    <div class="container history-grid">
      <div class="hleft">
        <div class="section-label">Our History</div>
        <h2>Ten Years of Building Bridges</h2>
        <p>NCIC was founded to do what no government office could do alone — build authentic, trust-based relationships between Delaware and international partners, then bring those relationships into formal government frameworks.</p>
        <p>We organized the trade mission that brought New Castle County leadership to Qiqihar. We arranged the delegation that came to Delaware to sign the sister city agreement. We connected the companies, the officials, and the communities that made it real.</p>
      </div>
      <div class="timeline">
        <div class="te"><span class="yr">2014</span><div><strong>NCIC Founded</strong>Established to connect NCC economic development with international investment, initial focus on Qiqihar.</div></div>
        <div class="te"><span class="yr">Nov 2014</span><div><strong>Sister City Agreement Signed</strong>Mayor Zhe Sun and a Qiqihar delegation signed the formal NCC-Qiqihar agreement in Delaware.</div></div>
        <div class="te"><span class="yr">Jul 2015</span><div><strong>Trade Mission to Qiqihar</strong>NCIC coordinated the NCC delegation — County Executive Gordon, Council President Bullock, and civic leaders — to China.</div></div>
        <div class="te"><span class="yr">Sep 2016</span><div><strong>Chinese Business Delegation</strong>COSCO, China Gezhouba Group, and other major enterprises visited Delaware for investment discussions.</div></div>
        <div class="te"><span class="yr">2026</span><div><strong>NCIC Reactivated</strong>With new county leadership, NCIC returns to activate the agreements it helped build — education-first.</div></div>
      </div>
    </div>
  </section>

  <!-- PARTNERSHIPS -->
  <section class="partnerships" id="partnerships">
    <div class="container">
      <div class="section-label">International Partnerships</div>
      <h2>Active Relationships</h2>
      <p class="intro">NCIC operates within New Castle County's formal international framework — the only county-level China partnership in Delaware, distinct from and independent of city-level arrangements.</p>
      <div class="city-cards">
        <div class="city-card">
          <img src="/images/qiqihar-city.png" alt="Qiqihar city" class="card-img" />
          <div class="card-body">
            <div class="flag">Heilongjiang Province · Northeast China</div>
            <h3>Qiqihar</h3>
            <div class="csub">Formal Sister City Agreement · New Castle County · Est. 2014</div>
            <p>A prefecture-level city of nearly 6 million people. NCIC arranged the agreement covering economy, trade, science, technology, culture, education, sports, and tourism.</p>
            <div class="cstats"><div><span>~6M</span><span>Population</span></div><div><span>$20B</span><span>GDP</span></div><div><span>2014</span><span>Agreement</span></div></div>
          </div>
        </div>
        <div class="city-card">
          <img src="/images/wilmington-aerial.png" alt="Wilmington Delaware" class="card-img" />
          <div class="card-body">
            <div class="flag">Zhejiang Province · East China</div>
            <h3>Ningbo</h3>
            <div class="csub">Friendship City · City of Wilmington · Est. 1988</div>
            <p>One of China's wealthiest cities with a GDP of $233 billion. Active interest in education curriculum exchange — 2024 delegation focused on vocational education.</p>
            <div class="cstats"><div><span>9M+</span><span>Population</span></div><div><span>$233B</span><span>GDP</span></div><div><span>1988</span><span>Friendship</span></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="mission">
    <div class="container mission-inner">
      <div class="gold-rule" style="margin:0 auto 32px"></div>
      <blockquote>"Our motivation is nothing new. We help people live better lives, achieve greater success, and create empowered futures — one relationship at a time."</blockquote>
      <div class="attr">New Castle International Corp. · Founded 2014</div>
    </div>
  </section>

  <!-- WHY NCC -->
  <section class="why" id="why">
    <div class="container">
      <div class="section-label" style="color:var(--gold)">Why New Castle County</div>
      <h2>Delaware's Strategic Advantages</h2>
      <div class="why-grid">
        <div class="wi"><h4>Geographic Position</h4><p>Midway between New York and D.C. at the center of the largest US economic corridor, with direct access to the Port of Wilmington.</p></div>
        <div class="wi"><h4>Port Infrastructure</h4><p>The Port of Wilmington — currently under expansion — is one of the most strategically located marine terminals on the US East Coast.</p></div>
        <div class="wi"><h4>Education Ecosystem</h4><p>Home to the University of Delaware and institutions actively seeking international curriculum partnerships and student exchange programming.</p></div>
        <div class="wi"><h4>Business Environment</h4><p>Delaware's legal and corporate infrastructure — the most business-friendly in the US — makes it a natural landing point for international companies.</p></div>
        <div class="wi"><h4>Government Relationships</h4><p>NCIC maintains direct working relationships with NCC Executive leadership and a track record of coordinating official government-to-government delegations.</p></div>
        <div class="wi"><h4>Community Infrastructure</h4><p>A diverse, internationally connected population with established community organizations that support cultural exchange at the neighborhood level.</p></div>
      </div>
    </div>
  </section>

  <!-- PARTNER CTA -->
  <section class="partner-cta">
    <div class="container partner-cta-inner">
      <div>
        <div class="section-label" style="color:var(--navy);opacity:.6">Work With Us</div>
        <h2>Is Your City Ready for the World?</h2>
        <p>NCIC facilitates international economic partnerships for cities, counties, and institutions across the Mid-Atlantic region. Express your interest and we'll be in touch.</p>
      </div>
      <a href="/partner" class="pcta-btn">Partner With Us →</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* HERO */
.hero {
  background: linear-gradient(to bottom, rgba(13,31,60,.7), rgba(13,31,60,.95)),
              url("/images/wilmington-waterfront.png") center/cover no-repeat;
  color: var(--offwhite);
  padding: 80px 48px;
  position: relative;
}
.hero-inner { max-width: 900px; margin: 0 auto; }
.hero-eyebrow { font-family:'Arial',sans-serif; font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--gold); margin-bottom:24px; display:flex; align-items:center; gap:12px; }
.hero-eyebrow::before { content:''; display:block; width:32px; height:1px; background:var(--gold); }
.hero h1 { font-size:clamp(32px,5vw,60px); margin-bottom:24px; letter-spacing:-.01em; line-height:1.1; }
.hero h1 em { font-style:normal; color:var(--gold); }
.hero-sub { font-family:'Arial',sans-serif; font-size:15px; color:#94A3B8; max-width:580px; line-height:1.7; margin-bottom:36px; }
.hero-cta { display:inline-block; background:var(--gold); color:var(--navy); padding:14px 28px; font-family:'Arial',sans-serif; font-size:11px; letter-spacing:.15em; text-transform:uppercase; font-weight:bold; transition:background .2s; text-decoration:none; }
.hero-cta:hover { background:#E0BC6A; }
.hero-stats { display:flex; gap:40px; margin-top:56px; padding-top:40px; border-top:1px solid rgba(201,168,76,.2); flex-wrap:wrap; }
.num { font-size:32px; color:var(--gold); display:block; line-height:1; margin-bottom:4px; }
.lbl { font-family:'Arial',sans-serif; font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:#64748B; }

/* PHOTO BAND */
.photo-band { background:var(--navy); padding:40px 0; text-align:center; }
.pb-label { font-family:'Arial',sans-serif; font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--gold); margin-bottom:16px; padding:0 24px; }
.pb-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:3px; margin-bottom:20px; }
.pb-grid a { display:block; overflow:hidden; }
.pb-grid img { width:100%; height:200px; object-fit:cover; display:block; transition:opacity .2s; }
.pb-grid img:hover { opacity:.8; }
.pb-cta { font-family:'Arial',sans-serif; font-size:11px; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); text-decoration:none; border-bottom:1px solid var(--gold); padding-bottom:2px; }

/* ABOUT */
.section { padding:64px 0; }
.section h2 { font-size:clamp(24px,3vw,38px); color:var(--navy); margin-bottom:16px; font-weight:normal; }
.intro { font-family:'Arial',sans-serif; font-size:15px; color:var(--muted); max-width:640px; line-height:1.7; margin-bottom:40px; }
.pillars { display:grid; grid-template-columns:1fr; gap:2px; background:var(--light); }
.pillar { background:var(--offwhite); padding:32px; }
.pnum { font-family:'Arial',sans-serif; font-size:11px; letter-spacing:.2em; color:var(--gold); margin-bottom:16px; display:block; }
.pbar { width:32px; height:2px; background:var(--gold); margin-bottom:20px; }
.pillar h3 { font-size:18px; color:var(--navy); margin-bottom:10px; font-weight:normal; }
.pillar p { font-family:'Arial',sans-serif; font-size:14px; color:var(--muted); line-height:1.7; }

/* HISTORY */
.history-band { background:var(--navy); padding:64px 0; color:var(--offwhite); }
.history-grid { display:grid; grid-template-columns:1fr; gap:48px; }
.hleft h2 { font-size:clamp(24px,3vw,38px); color:var(--offwhite); margin-bottom:20px; font-weight:normal; }
.hleft p { font-family:'Arial',sans-serif; font-size:14px; color:#94A3B8; line-height:1.8; margin-bottom:14px; }
.timeline { display:flex; flex-direction:column; }
.te { display:grid; grid-template-columns:80px 1fr; gap:16px; padding:20px 0; border-bottom:1px solid rgba(201,168,76,.15); }
.te:last-child { border-bottom:none; }
.yr { font-family:'Arial',sans-serif; font-size:10px; letter-spacing:.1em; color:var(--gold); padding-top:3px; }
.te div { font-family:'Arial',sans-serif; font-size:13px; color:#CBD5E0; line-height:1.6; }
.te div strong { color:var(--offwhite); display:block; margin-bottom:4px; }

/* PARTNERSHIPS */
.partnerships { padding:64px 0; background:var(--light); }
.partnerships h2 { font-size:clamp(24px,3vw,38px); color:var(--navy); margin-bottom:16px; font-weight:normal; }
.city-cards { display:grid; grid-template-columns:1fr; gap:2px; margin-top:32px; }
.city-card { background:var(--offwhite); overflow:hidden; }
.card-img { width:100%; height:200px; object-fit:cover; display:block; }
.card-body { padding:28px; }
.flag { font-family:'Arial',sans-serif; font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--muted); margin-bottom:8px; }
.city-card h3 { font-size:24px; color:var(--navy); margin-bottom:6px; font-weight:normal; }
.csub { font-family:'Arial',sans-serif; font-size:11px; color:var(--gold); letter-spacing:.08em; margin-bottom:14px; }
.city-card p { font-family:'Arial',sans-serif; font-size:14px; color:var(--muted); line-height:1.7; }
.cstats { margin-top:20px; padding-top:20px; border-top:1px solid var(--light); display:flex; gap:28px; }
.cstats div span:first-child { display:block; font-size:20px; color:var(--navy); margin-bottom:2px; }
.cstats div span:last-child { font-family:'Arial',sans-serif; font-size:9px; letter-spacing:.15em; text-transform:uppercase; color:var(--muted); }

/* MISSION */
.mission { padding:64px 0; background:var(--offwhite); text-align:center; }
.mission-inner { max-width:680px; margin:0 auto; padding:0 24px; }
.mission blockquote { font-size:clamp(18px,2.5vw,26px); color:var(--navy); line-height:1.5; margin-bottom:24px; font-style:italic; }
.attr { font-family:'Arial',sans-serif; font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); }

/* WHY */
.why { background:var(--slate); padding:64px 0; color:var(--offwhite); }
.why h2 { font-size:clamp(24px,3vw,38px); color:var(--offwhite); margin-bottom:32px; font-weight:normal; }
.why-grid { display:grid; grid-template-columns:1fr; gap:28px; }
.wi { border-left:2px solid var(--gold); padding-left:20px; }
.wi h4 { font-size:15px; color:var(--offwhite); margin-bottom:8px; font-weight:normal; }
.wi p { font-family:'Arial',sans-serif; font-size:13px; color:#94A3B8; line-height:1.7; }

/* PARTNER CTA */
.partner-cta { background:var(--gold); padding:56px 0; }
.partner-cta-inner { display:flex; flex-direction:column; gap:28px; }
.partner-cta h2 { font-size:clamp(22px,3vw,36px); color:var(--navy); margin-bottom:12px; font-weight:normal; }
.partner-cta p { font-family:'Arial',sans-serif; font-size:14px; color:var(--navy); opacity:.8; line-height:1.7; }
.pcta-btn { display:inline-block; background:var(--navy); color:var(--offwhite); padding:16px 28px; font-family:'Arial',sans-serif; font-size:11px; letter-spacing:.2em; text-transform:uppercase; text-decoration:none; transition:background .2s; align-self:flex-start; }
.pcta-btn:hover { background:var(--slate); }

/* TABLET+ */
@media (min-width: 640px) {
  .pb-grid { grid-template-columns:repeat(3,1fr); }
  .pb-grid img { height:220px; }
  .pillars { grid-template-columns:repeat(3,1fr); }
  .city-cards { grid-template-columns:repeat(2,1fr); }
  .why-grid { grid-template-columns:repeat(2,1fr); }
  .partner-cta-inner { flex-direction:row; align-items:center; justify-content:space-between; }
}

/* DESKTOP */
@media (min-width: 1024px) {
  .hero { padding:96px 48px; }
  .history-grid { grid-template-columns:1fr 1fr; gap:80px; }
  .pb-grid img { height:260px; }
}
</style>
