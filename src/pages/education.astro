---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Education — New Castle International Corp.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <div class="section-label">Education</div>
      <h1>The Most Educated<br><em>Corridor in America</em></h1>
      <p class="sub">New Castle County sits at the center of the most densely concentrated higher education system in the United States. Within 90 minutes: 40+ colleges and universities serving over 500,000 students — including some of the world's most prestigious research institutions.</p>
    </div>
  </section>

  <section class="edu-stats">
    <div class="container stats-grid">
      <div class="stat-card"><span class="snum">40+</span><span class="slbl">Colleges &amp; Universities Within 90 Min</span></div>
      <div class="stat-card"><span class="snum">500K+</span><span class="slbl">College Students in the Corridor</span></div>
      <div class="stat-card"><span class="snum">Top 50</span><span class="slbl">University of Delaware National Ranking</span></div>
      <div class="stat-card"><span class="snum">100+</span><span class="slbl">Countries Represented at UD</span></div>
    </div>
  </section>

  <section class="local-universities">
    <div class="container">
      <div class="section-label">Delaware Institutions</div>
      <h2>World-Class Education Right Here</h2>
      <div class="univ-grid">
        <div class="univ-card featured">
          <div class="univ-name">University of Delaware</div>
          <div class="univ-location">Newark, Delaware</div>
          <p>A top-50 national research university with over 23,000 students from more than 100 countries. UD is a Carnegie R1 research institution — the highest classification — with significant federal research funding and a robust international student program.</p>
          <p>UD's Institute for Global Studies coordinates study abroad, international partnerships, and exchange programs. The university maintains relationships with partner institutions across Asia, Europe, and Latin America.</p>
          <div class="univ-highlights">
            <div class="uh">Strong engineering, business, and life sciences programs</div>
            <div class="uh">Active Chinese student association and Mandarin programs</div>
            <div class="uh">Research partnerships with international institutions</div>
            <div class="uh">Potential LAYERS curriculum integration partner</div>
          </div>
        </div>
        <div class="univ-card">
          <div class="univ-name">Wilmington University</div>
          <div class="univ-location">New Castle, Delaware</div>
          <p>One of Delaware's largest universities with over 18,000 students. WilmU focuses on applied, career-oriented education with strong programs in business, education, nursing, and technology. An accessible, affordable pathway for international students entering the US workforce.</p>
          <div class="univ-highlights">
            <div class="uh">Strong international student support services</div>
            <div class="uh">Applied business and technology programs</div>
            <div class="uh">Multiple Delaware campuses including New Castle and Dover</div>
          </div>
        </div>
        <div class="univ-card">
          <div class="univ-name">Delaware Technical Community College</div>
          <div class="univ-location">Statewide, Delaware</div>
          <p>Delaware's largest post-secondary institution serves 13,000+ students annually across four campuses. Del Tech is a critical workforce development partner — training workers for Delaware's advanced manufacturing, healthcare, and technology sectors.</p>
          <div class="univ-highlights">
            <div class="uh">Workforce training for advanced manufacturing</div>
            <div class="uh">Healthcare and technology programs</div>
            <div class="uh">Gateway to UD transfer programs</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="philly-corridor">
    <div class="container">
      <div class="section-label">The Philadelphia Corridor</div>
      <h2>World-Renowned Institutions Within 30 Miles</h2>
      <p class="section-intro">Delaware's position within the Philadelphia metropolitan area gives international students direct access to some of the world's most prestigious universities — all within a short drive or train ride.</p>
      <div class="philly-grid">
        <div class="philly-school"><h4>University of Pennsylvania</h4><p>Ivy League. Wharton School of Business. World-class research. 30 min from Wilmington.</p></div>
        <div class="philly-school"><h4>Drexel University</h4><p>Top co-op engineering program. Strong technology and business schools. 25 min from Wilmington.</p></div>
        <div class="philly-school"><h4>Temple University</h4><p>Major research university, 39,000 students. Strong business, law, and medicine programs.</p></div>
        <div class="philly-school"><h4>Villanova University</h4><p>Top-ranked business and engineering. Catholic research university. 20 min from Wilmington.</p></div>
        <div class="philly-school"><h4>Thomas Jefferson University</h4><p>Leading health sciences university. Hospital system integration. Medical and design programs.</p></div>
        <div class="philly-school"><h4>Swarthmore College</h4><p>Top-5 liberal arts college nationally. 15 min from Wilmington. Rhodes Scholar pipeline.</p></div>
      </div>
    </div>
  </section>

  <section class="ise-section">
    <div class="container ise-inner">
      <div>
        <img src="/images/gallery/ise-card.jpg" alt="International Study Exchange" style="width:100%;max-width:340px;display:block;margin-bottom:24px" />
        <div class="section-label" style="color:var(--gold)">NCIC Partner</div>
        <h2>International Study Exchange</h2>
        <p>NCIC works directly with International Study Exchange (ISE), founded by NCIC co-founder Winsom Chinupakit, to provide a full suite of student placement and cultural exchange services.</p>
        <p>ISE specializes in matching international students with appropriate Delaware and Philadelphia-area institutions — handling visa support, housing placement, orientation programming, and ongoing student services throughout their academic stay.</p>
        <div class="ise-services">
          <div class="ise-service">University placement and application support</div>
          <div class="ise-service">Student visa (F-1) guidance and processing</div>
          <div class="ise-service">Housing and community integration</div>
          <div class="ise-service">Cultural orientation programming</div>
          <div class="ise-service">Faculty and curriculum exchange facilitation</div>
          <div class="ise-service">Chinese-English language and translation support</div>
        </div>
      </div>
      <div>
        <div class="section-label" style="color:var(--gold)">Investment &amp; Residency</div>
        <h2>The EB-5 Investor Visa</h2>
        <p>New Castle County qualifies as a federal Targeted Employment Area (TEA) — which means international investors can pursue permanent US residency through the EB-5 Immigrant Investor Program at the minimum investment threshold.</p>
        <div class="eb5-box">
          <div class="eb5-stat"><span>$800,000</span><span>Minimum investment in a Targeted Employment Area</span></div>
          <div class="eb5-stat"><span>10 Jobs</span><span>Must be created or preserved for US workers</span></div>
          <div class="eb5-stat"><span>Green Card</span><span>Path to US permanent residency for investor and family</span></div>
          <div class="eb5-stat"><span>NCC Qualifies</span><span>New Castle County is a designated TEA</span></div>
        </div>
        <p style="font-family:'Arial',sans-serif;font-size:13px;color:#94A3B8;line-height:1.7;margin-top:20px">The EB-5 program is administered by USCIS. NCIC can connect prospective investors with qualified immigration attorneys and regional center operators. This is not legal advice.</p>

        <div class="section-label" style="color:var(--gold);margin-top:48px">Educational Technology</div>
        <h2>LAYERS Curriculum Framework</h2>
        <p>NCIC co-founder Dan Lieberman is the developer of LAYERS — an educational technology framework designed for modern curriculum development and institutional exchange programs.</p>
        <p>LAYERS provides a structured methodology for developing cross-cultural educational programs — adaptable to K-12, higher education, and professional training contexts. NCIC is actively exploring LAYERS integration with Delaware school districts and potential curriculum export to Qiqihar partner schools.</p>
        <a href="/partner" class="section-cta" style="margin-top:16px;display:inline-block">Inquire About Educational Programs →</a>
      </div>
    </div>
  </section>

  <section class="edu-cta">
    <div class="container edu-cta-inner">
      <div>
        <h2>Interested in Educational Exchange?</h2>
        <p>Whether you're a student, institution, or government looking to build educational bridges with the Delaware-Philadelphia corridor — we want to hear from you.</p>
      </div>
      <a href="/partner" class="gold-btn">Get in Touch →</a>
    </div>
  </section>

  <Footer />
</Base>

<style>
.page-hero{background:var(--navy);padding:80px 0;border-bottom:2px solid var(--gold);color:var(--offwhite)}
.page-hero h1{font-size:clamp(28px,4vw,50px);font-weight:normal;margin-bottom:20px;line-height:1.1}
.page-hero h1 em{font-style:normal;color:var(--gold)}
.page-hero .sub{font-family:'Arial',sans-serif;font-size:15px;color:#94A3B8;max-width:660px;line-height:1.8}
.edu-stats{background:var(--navy);padding:48px 0}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:rgba(255,255,255,.05)}
.stat-card{background:var(--navy);padding:32px 24px;text-align:center;border:1px solid rgba(201,168,76,.1)}
.snum{display:block;font-size:clamp(22px,3vw,32px);color:var(--gold);margin-bottom:8px}
.slbl{font-family:'Arial',sans-serif;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#64748B}
.local-universities{padding:80px 0;background:var(--offwhite)}
.local-universities h2{font-size:clamp(24px,3vw,36px);color:var(--navy);margin-bottom:40px;font-weight:normal}
.univ-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:2px;background:var(--light)}
.univ-card{background:var(--offwhite);padding:32px}
.univ-card.featured{background:var(--navy);color:var(--offwhite)}
.univ-name{font-size:18px;color:var(--gold);margin-bottom:4px;font-family:'Georgia',serif}
.univ-location{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:#64748B;margin-bottom:16px}
.univ-card p{font-family:'Arial',sans-serif;font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:12px}
.univ-card.featured p{color:#94A3B8}
.univ-highlights{margin-top:20px;padding-top:20px;border-top:1px solid rgba(201,168,76,.2)}
.uh{font-family:'Arial',sans-serif;font-size:12px;color:#CBD5E0;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:center;gap:8px}
.uh::before{content:'✓';color:var(--gold);flex-shrink:0}
.philly-corridor{padding:80px 0;background:var(--light)}
.philly-corridor h2{font-size:clamp(24px,3vw,36px);color:var(--navy);margin-bottom:16px;font-weight:normal}
.section-intro{font-family:'Arial',sans-serif;font-size:15px;color:var(--muted);max-width:640px;line-height:1.7;margin-bottom:40px}
.philly-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:#D0C9BC}
.philly-school{background:var(--offwhite);padding:28px;border-left:3px solid var(--gold)}
.philly-school h4{font-size:16px;color:var(--navy);margin-bottom:10px;font-weight:normal}
.philly-school p{font-family:'Arial',sans-serif;font-size:13px;color:var(--muted);line-height:1.6}
.ise-section{padding:80px 0;background:var(--navy);color:var(--offwhite)}
.ise-inner{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
.ise-section h2{font-size:clamp(22px,3vw,32px);color:var(--offwhite);margin-bottom:16px;font-weight:normal}
.ise-section p{font-family:'Arial',sans-serif;font-size:14px;color:#94A3B8;line-height:1.8;margin-bottom:14px}
.ise-services{display:flex;flex-direction:column;gap:0;margin-top:20px}
.ise-service{font-family:'Arial',sans-serif;font-size:13px;color:#CBD5E0;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.07);display:flex;align-items:center;gap:10px}
.ise-service::before{content:'→';color:var(--gold);flex-shrink:0}
.eb5-box{display:flex;flex-direction:column;gap:2px;margin:20px 0}
.eb5-stat{background:rgba(201,168,76,.08);border-left:3px solid var(--gold);padding:16px 20px}
.eb5-stat span:first-child{display:block;font-size:20px;color:var(--gold);margin-bottom:4px}
.eb5-stat span:last-child{font-family:'Arial',sans-serif;font-size:12px;color:#94A3B8}
.section-cta{font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);text-decoration:none;border-bottom:1px solid var(--gold);padding-bottom:2px}
.edu-cta{background:var(--gold);padding:64px 0}
.edu-cta-inner{display:flex;justify-content:space-between;align-items:center;gap:48px;flex-wrap:wrap}
.edu-cta h2{font-size:clamp(22px,3vw,34px);color:var(--navy);margin-bottom:12px;font-weight:normal}
.edu-cta p{font-family:'Arial',sans-serif;font-size:15px;color:var(--navy);opacity:.8;max-width:480px}
.gold-btn{background:var(--navy);color:var(--offwhite);padding:16px 32px;font-family:'Arial',sans-serif;font-size:11px;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;white-space:nowrap;flex-shrink:0;transition:background .2s}
.gold-btn:hover{background:var(--slate)}
@media(max-width:1024px){.univ-grid{grid-template-columns:1fr 1fr}}
@media(max-width:900px){.ise-inner,.edu-cta-inner{grid-template-columns:1fr;flex-direction:column;gap:40px}.philly-grid{grid-template-columns:repeat(2,1fr)}.stats-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.philly-grid,.univ-grid,.stats-grid{grid-template-columns:1fr}}
</style>
